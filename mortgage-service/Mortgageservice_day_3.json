    },
    {
      "name": "5. ACTUATOR (Public)",
      "item": [
        {
          "name": "5.1 Health Check - No Token (Expect 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Status is UP', function() { pm.expect(pm.response.json().status).to.eql('UP'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    }
  ]
}